{
  "extends": "../../packages/typescript-config/react-native.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"]
    },
    "noEmit": true
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "app.config.ts",
    "expo-env.d.ts"
  ],
  "exclude": ["node_modules", "dist", ".expo", "src/**/*.test.ts"]
}
