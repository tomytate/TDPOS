{
  "extends": "../../packages/typescript-config/react-native.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"],
      "@haroldtran/react-native-thermal-printer": ["./src/types/thermal-printer"]
    },
    "noEmit": true
  },
  "include": ["app/**/*.ts", "app/**/*.tsx", "src/**/*.ts", "src/**/*.tsx", "app.config.ts"],
  "exclude": ["node_modules", "dist", ".expo", "src/**/*.test.ts"]
}
