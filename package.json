{
  "name": "tdpos",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:mobile": "turbo run dev --filter=@tdpos/mobile",
    "dev:web": "turbo run dev --filter=@tdpos/web",
    "mobile:start": "bun --filter @tdpos/mobile start",
    "mobile:ios": "bun --filter @tdpos/mobile ios",
    "mobile:android": "bun --filter @tdpos/mobile android",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:mobile": "turbo run test --filter=@tdpos/mobile",
    "check:toolchain": "node scripts/check-toolchain.mjs",
    "check:sqlite-schema": "node scripts/check-local-sqlite-schema.mjs",
    "check:patterns": "node scripts/check-forbidden-patterns.mjs",
    "check:doc-links": "node scripts/check-doc-links.mjs",
    "check:foundation": "bun run format:check && bun run check:sqlite-schema && bun run check:patterns && bun run check:doc-links && bun run typecheck && bun run lint && bun run test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "db:seed": "supabase db seed",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/bun": "^1.3.13",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.5.0",
    "turbo": "^2.9.9",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  },
  "packageManager": "bun@1.3.13"
}
